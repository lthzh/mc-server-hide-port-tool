{
  "name": "hide-port-tool",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./src/styles/app.css -o ./public/static/app.css --minify",
    "build:vendor": "node scripts/build-browser-assets.cjs",
    "build": "pnpm run build:css && pnpm run build:vendor",
    "validate:migrations": "node scripts/validate-production-migrations.cjs",
    "predev": "pnpm run build",
    "dev": "wrangler dev",
    "predeploy": "pnpm run build",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@better-auth/passkey": "1.6.23",
    "@simplewebauthn/browser": "13.3.0",
    "better-auth": "1.6.23",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "miniflare": "4.20260706.0",
    "tailwindcss": "3.4.17",
    "typescript": "^7.0.2",
    "vitest": "4.1.10",
    "wrangler": "^4.108.0"
  }
}
